{
  "name": "mhs-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test-conn": "node scripts/test-connection.js",
    "introspect": "node scripts/introspect.js",
    "build": "vite build",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "docx": "^9.7.1",
    "vite": "^5.4.0"
  }
}
