# Copy this file to `.env` and fill in real values. Do NOT commit the .env file.

# ── Odoo Postgres (read-only DB user) ──
PGHOST=odoo-prod-db.cz4siwieazgp.ap-south-1.rds.amazonaws.com
PGPORT=5432
PGUSER=mhs_read_only
PGPASSWORD=replace-me
PGDATABASE=odoo
PGSSLMODE=require

# ── Session / JWT ──
# Generate with:  openssl rand -base64 48
SESSION_SECRET=replace-with-48-byte-random-string
SESSION_TTL_HOURS=12

# ── Demo bypass (REMOVE in production) ──
DEMO_LOGIN=demo@mhs.local
DEMO_PASSWORD=Demo@2026

# ── Odoo Web RPC (for per-caller table + headline KPIs) ──
ODOO_URL=https://mhs.doneztech.com
ODOO_DB=odoo
ODOO_SERVICE_LOGIN=replace-me@mhs.com
ODOO_SERVICE_PASSWORD=replace-me

# ── Optional ──
PORT=3000
